maximize = true

# Override shell
# command = zsh

theme = catppuccin-frappe.conf

# Font
font-family = Zed Mono
font-family = Zed Mono NF
font-family = ZedMono Nerd Font Mono
font-size = 16

quick-terminal-size = 65%

# No window decorations
window-decoration = none
window-show-tab-bar = never
# gtk-titlebar-style=tabs

# Shader
# custom-shader = shaders/bettercrt.glsl

# Background
config-file = "background"
config-file = "?background.local"

# Keybinds
config-file = "keybinds"

# Local extended config
config-file = "?config.local"
